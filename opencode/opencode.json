{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth@latest",
    "opencode-mystatus",
    "@howaboua/opencode-planning-toolkit@latest"
  ],
  "provider": {
    "ollama": {
      "models": {
        "glm-5:cloud": {
          "_launch": true,
          "limit": {
            "context": 202752,
            "output": 131072
          },
          "name": "glm-5:cloud"
        },
        "kimi-k2.5:cloud": {
          "_launch": true,
          "limit": {
            "context": 262144,
            "output": 262144
          },
          "name": "kimi-k2.5:cloud"
        },
        "minimax-m2.5:cloud": {
          "_launch": true,
          "limit": {
            "context": 204800,
            "output": 128000
          },
          "name": "minimax-m2.5:cloud"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  },
  "agent": {
    "build": {
      "description": "Build agent - hidden from autocomplete",
      "mode": "primary",
      "hidden": true
    },
    "plan": {
      "description": "Plan agent - hidden from autocomplete",
      "mode": "primary",
      "hidden": true
    },
    "general": {
      "description": "General-purpose agent for researching complex questions and executing multi-step tasks",
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free"
    },
    "explore": {
      "description": "Read-only subagent for fast codebase exploration at different thoroughness levels",
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free"
    },
    "CoderAgent": {
      "description": "Executes coding subtasks in sequence, ensuring completion as specified",
      "mode": "subagent",
      "model": "opencode/kimi-k2.5"
    },
    "CodeReviewer": {
      "description": "Code review, security, and quality assurance agent",
      "mode": "subagent",
      "model": "opencode/kimi-k2.5"
    },
    "BuildAgent": {
      "description": "Type check and build validation agent",
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free"
    },
    "TestEngineer": {
      "description": "Test authoring and TDD agent",
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free"
    },
    "OpenDevopsSpecialist": {
      "description": "DevOps specialist for CI/CD, infrastructure as code, deployment",
      "mode": "subagent",
      "model": "opencode/kimi-k2.5"
    },
    "OpenFrontendSpecialist": {
      "description": "Frontend UI design specialist for design systems, themes, animations",
      "mode": "subagent",
      "model": "opencode/kimi-k2.5"
    },
    "ContextOrganizer": {
      "description": "Organizes and generates context files for optimal knowledge management",
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free"
    },
    "DocWriter": {
      "description": "Documentation authoring agent",
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free"
    },
    "ExternalScout": {
      "description": "Fetches live, version-specific documentation for libraries and frameworks",
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free"
    },
    "ContextScout": {
      "description": "Discovers and recommends context files from .opencode/context/",
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free"
    },
    "TaskManager": {
      "description": "JSON-driven task breakdown specialist with dependency tracking",
      "mode": "subagent",
      "model": "opencode/kimi-k2.5"
    }
  }
}
