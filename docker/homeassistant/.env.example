# Home Assistant configuration
#
# Running as a Docker container (not HAOS).
# All 2000+ core integrations work. Add-ons are NOT available — run equivalent
# services as separate Docker containers (e.g. Mosquitto MQTT, Node-RED, ESPHome).
#
# After first start, visit https://HA_HOSTNAME to complete onboarding.
# Config is persisted in ./config/ (gitignored).

# HA_HOSTNAME: The public hostname Traefik routes to Home Assistant.
# Must match the entry in your Cloudflare tunnel config.yml ingress rules.
# Example: ha.yourdomain.com
HA_HOSTNAME=ha.yourdomain.com

# HA_TZ: Timezone for Home Assistant (used for automations, history, etc.)
# List of valid values: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Example: America/New_York, Europe/Lisbon, Asia/Tokyo
HA_TZ=America/New_York
