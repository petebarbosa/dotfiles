# Vaultwarden password manager configuration

# DOMAIN: The full public-facing HTTPS URL of this Vaultwarden instance.
# Used internally by Vaultwarden for generating links in emails, attachments, etc.
# Example: https://vault.yourdomain.com
DOMAIN=https://subdomain.yourdomain.com

# VW_HOSTNAME: The hostname Traefik uses to route requests to Vaultwarden.
# Must match the subdomain configured in your Cloudflare tunnel ingress rules.
# Example: vault.yourdomain.com (no https://)
VW_HOSTNAME=subdomain.yourdomain.com
