# Shared PostgreSQL instance
#
# This is a shared database server for all applications that need PostgreSQL.
# Each application gets its own database within this instance.
#
# To create a database for a new app after the container is running:
#   docker exec -it postgres psql -U $POSTGRES_USER -c "CREATE DATABASE myapp;"
#
# Connection string for applications:
#   postgresql://POSTGRES_USER:POSTGRES_PASSWORD@postgres:5432/<app_database_name>

# POSTGRES_USER: Superuser account name for the PostgreSQL instance.
POSTGRES_USER=postgres

# POSTGRES_PASSWORD: Password for the superuser. Use a long random string.
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_use_a_long_random_string

# POSTGRES_DB: The default database created on first start.
# This is the admin/maintenance database. Each app gets its own separate database.
POSTGRES_DB=postgres
